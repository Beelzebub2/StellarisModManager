<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.VersionBrowserView"
             x:DataType="vm:VersionBrowserViewModel"
             FontFamily="Inter, Segoe UI">

    <UserControl.Styles>
        <Style Selector="Border.mod-card">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="Border.mod-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16">

        <!-- Row 0: Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto,*,Auto" Margin="0,0,0,12">

            <!-- Col 0: Version ComboBox -->
            <ComboBox Grid.Column="0"
                      ItemsSource="{Binding VersionItems}"
                      SelectedItem="{Binding SelectedVersion}"
                      MinWidth="240"
                      Background="{DynamicResource Theme.SurfaceBg}"
                      BorderBrush="{DynamicResource Theme.Border}"
                      CornerRadius="8"
                      Padding="10,8">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:VersionDropdownItem">
                        <TextBlock Text="{Binding DropdownText}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Col 1: Mod count -->
            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayedModCount, StringFormat='{}{0} mods'}"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0" />

            <!-- Col 2: Show older versions checkbox -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="16,0,0,0">
                <CheckBox IsChecked="{Binding ShowOlderVersions}" />
                <TextBlock Text="Show older versions"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Col 4: Search box -->
            <TextBox Grid.Column="4"
                     Text="{Binding SearchText}"
                     Watermark="Search mods..."
                     MinWidth="200"
                     Background="{DynamicResource Theme.SurfaceBg}"
                     BorderBrush="{DynamicResource Theme.Border}"
                     CornerRadius="8"
                     Padding="10,8" />
        </Grid>

        <!-- Row 1: Mod grid -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DisplayedMods}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:VersionModCard">
                        <Border Classes="mod-card"
                                Width="160"
                                Height="190"
                                Margin="4"
                                ClipToBounds="True">
                            <Grid RowDefinitions="120,*">

                                <!-- Row 0: Thumbnail or placeholder -->
                                <Panel Grid.Row="0">
                                    <Image Source="{Binding ThumbnailUrl}"
                                           Stretch="UniformToFill"
                                           IsVisible="{Binding HasThumbnail}" />
                                    <Border Background="{DynamicResource Theme.PanelBg}"
                                            IsVisible="{Binding !HasThumbnail}">
                                        <TextBlock Text="{Binding PlaceholderLetter}"
                                                   FontSize="48"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Theme.TextMuted}" />
                                    </Border>
                                </Panel>

                                <!-- Row 1: Mod name and version badge -->
                                <Grid Grid.Row="1" Margin="8,6" RowDefinitions="*,Auto">
                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Name}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                               VerticalAlignment="Top" />
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="4"
                                            Padding="5,2"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding GameVersionBadge}"
                                                   Foreground="White"
                                                   FontSize="9"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
