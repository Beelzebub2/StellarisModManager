<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.VersionBrowserView"
             x:Name="Root"
             x:DataType="vm:VersionBrowserViewModel"
             FontFamily="Inter, Segoe UI">

    <UserControl.Styles>
        <Style Selector="Border.mod-card">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.16" />
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.20" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.mod-card:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Accent}" />
        </Style>
        <Style Selector="Button.mod-action">
            <Setter Property="Background" Value="#2F6FEB" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.mod-action:pointerover">
            <Setter Property="Background" Value="#2E8B57" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.mod-action.installed">
            <Setter Property="Background" Value="#E3B341" />
            <Setter Property="Foreground" Value="#1A1A1A" />
        </Style>
        <Style Selector="Button.mod-action.installed:pointerover">
            <Setter Property="Background" Value="#C93C37" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.mod-action.busy">
            <Setter Property="Background" Value="#4B5568" />
        </Style>
        <Style Selector="Button.mod-action.error">
            <Setter Property="Background" Value="#C97A19" />
        </Style>
        <Style Selector="Border.version-badge">
            <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="5,2" />
        </Style>
        <Style Selector="Border.compat-badge">
            <Setter Property="Background" Value="#244734" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="5,2" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="16">

        <!-- Row 0: Toolbar -->
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,12">
            <WrapPanel Orientation="Horizontal" ItemHeight="36" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding VersionItems}"
                          SelectedItem="{Binding SelectedVersion}"
                          MinWidth="210"
                          MaxWidth="260"
                          Background="{DynamicResource Theme.SurfaceBg}"
                          BorderBrush="{DynamicResource Theme.Border}"
                          CornerRadius="8"
                          Padding="10,8"
                          Margin="0,0,8,0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:VersionDropdownItem">
                            <TextBlock Text="{Binding DropdownText}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding DisplayedModCount, StringFormat='{}{0} mods'}"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <CheckBox IsChecked="{Binding ShowOlderVersions}"
                          Content="Show older versions"
                          Foreground="{DynamicResource Theme.TextMuted}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />

                <StackPanel Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <TextBlock Text="Sort"
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding SortModes}"
                              SelectedItem="{Binding SelectedSortMode}"
                              MinWidth="160"
                              MaxWidth="210"
                              Background="{DynamicResource Theme.SurfaceBg}"
                              BorderBrush="{DynamicResource Theme.Border}"
                              CornerRadius="8"
                              Padding="10,6">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:VersionSortModeItem">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <TextBox Text="{Binding SearchText}"
                         Watermark="Search mods..."
                         Width="230"
                         MinWidth="180"
                         Background="{DynamicResource Theme.SurfaceBg}"
                         BorderBrush="{DynamicResource Theme.Border}"
                         CornerRadius="8"
                         Padding="10,8"
                         Margin="0,0,8,0" />
            </WrapPanel>

            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       FontSize="11"
                       IsVisible="{Binding !ShowLoadingState}"
                       MaxLines="1"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid x:Name="ResultsContentPanel">
                <!-- Loading indicator -->
                <StackPanel IsVisible="{Binding ShowLoadingState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <ProgressBar IsIndeterminate="True"
                                 Width="200"
                                 Height="4"
                                 Foreground="{DynamicResource Theme.Accent}" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="13"
                               MaxWidth="560"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Empty state: no mods installed at all -->
                <StackPanel IsVisible="{Binding ShowNoModsState}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="No workshop mods found."
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Try another version or broaden the query (for example, 4.2 instead of 4.2.4)."
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="13"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Empty state: mods exist but none match current filter -->
                <TextBlock Text="No mods found for this version."
                           IsVisible="{Binding ShowFilteredEmptyState}"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="0,40,0,0" />

                <!-- Mod grid -->
                <ScrollViewer x:Name="ResultsScrollViewer"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,0,0,56"
                              IsVisible="{Binding HasResults}">
                    <ItemsControl ItemsSource="{Binding DisplayedMods}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:VersionModCard">
                                <Border Classes="mod-card"
                                        Width="174"
                                        Height="244"
                                        Margin="4"
                                        ClipToBounds="True"
                                        Opacity="0"
                                        AttachedToVisualTree="OnModCardAttachedToVisualTree"
                                        PointerPressed="OnModCardPointerPressed">
                                    <Grid RowDefinitions="120,*,Auto">

                                        <!-- Row 0: Thumbnail or placeholder -->
                                        <Panel Grid.Row="0">
                                            <Image Source="{Binding ThumbnailImage}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasThumbnail}" />
                                            <Border Background="{DynamicResource Theme.PanelBg}"
                                                    IsVisible="{Binding !HasThumbnail}">
                                                <TextBlock Text="{Binding PlaceholderLetter}"
                                                           FontSize="48"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Theme.TextMuted}" />
                                            </Border>
                                        </Panel>

                                        <!-- Row 1: Mod name and version badge -->
                                        <Grid Grid.Row="1" Margin="8,6" RowDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="2"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Theme.TextPrimary}"
                                                       VerticalAlignment="Top"
                                                       ToolTip.Tip="{Binding Name}" />
                                            <Border Grid.Row="1"
                                                    Classes="version-badge"
                                                    HorizontalAlignment="Left"
                                                    ToolTip.Tip="{Binding GameVersionBadge, StringFormat='Version tag: {0}'}">
                                                <TextBlock Text="{Binding GameVersionBadge}"
                                                           Foreground="White"
                                                           FontSize="9"
                                                           FontWeight="SemiBold" />
                                            </Border>

                                            <StackPanel Grid.Row="2" Spacing="4">
                                                <Border Classes="compat-badge"
                                                        HorizontalAlignment="Left"
                                                        IsVisible="{Binding HasCommunityWorks}"
                                                        ToolTip.Tip="{Binding CommunityWorksBadge}">
                                                    <TextBlock Text="{Binding CommunityWorksBadge}"
                                                               Foreground="White"
                                                               FontSize="9"
                                                               FontWeight="SemiBold" />
                                                </Border>

                                                <TextBlock Text="{Binding SubscriberSummary}"
                                                           Foreground="{DynamicResource Theme.TextMuted}"
                                                           FontSize="9"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip.Tip="{Binding SubscriberSummary}" />
                                            </StackPanel>
                                        </Grid>

                                        <Button Grid.Row="2"
                                                Margin="8,0,8,8"
                                                Classes="mod-action"
                                                Classes.installed="{Binding IsInstalledState}"
                                                Classes.busy="{Binding IsBusyState}"
                                                Classes.error="{Binding IsErrorState}"
                                                Click="OnCardActionClick"
                                                PointerEntered="OnCardActionPointerEntered"
                                                PointerExited="OnCardActionPointerExited"
                                                ToolTip.Tip="{Binding ActionButtonTooltip}"
                                                IsEnabled="{Binding IsActionEnabled}">
                                            <TextBlock Text="{Binding ActionButtonText}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </Button>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,10"
                        IsVisible="{Binding HasResults}">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Button Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoToPreviousPage}"
                                ToolTip.Tip="Go to previous page"
                                Background="{DynamicResource Theme.SurfaceBg}"
                                BorderBrush="{DynamicResource Theme.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,7">
                            <TextBlock Text="Previous"
                                       Foreground="{DynamicResource Theme.TextPrimary}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Button>

                        <Border Background="{DynamicResource Theme.SurfaceBg}"
                                BorderBrush="{DynamicResource Theme.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,7">
                            <TextBlock Text="{Binding ResultPageText}"
                                       Foreground="{DynamicResource Theme.TextMuted}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>

                        <Button Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoToNextPage}"
                                ToolTip.Tip="Go to next page or scan more results"
                                Background="{DynamicResource Theme.SurfaceBg}"
                                BorderBrush="{DynamicResource Theme.Border}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,7">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="{Binding NextPageButtonText}"
                                           Foreground="{DynamicResource Theme.TextPrimary}"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                                <ProgressBar IsIndeterminate="True"
                                             Width="26"
                                             Height="4"
                                             IsVisible="{Binding IsScanningMore}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="ModBrowserPanel"
                    IsVisible="False"
                    Background="{DynamicResource Theme.AppBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Background="{DynamicResource Theme.PanelBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="8">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Button Grid.Column="0"
                                    Classes="mod-action"
                                    Width="92"
                                    Click="BackToResultsButton_Click">
                                <TextBlock Text="Back"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                            </Button>

                            <TextBlock Grid.Column="1"
                                       x:Name="ModBrowserTitleText"
                                       Margin="10,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource Theme.TextPrimary}"
                                       FontWeight="SemiBold" />

                            <Button Grid.Column="2"
                                    Width="34"
                                    Height="30"
                                    Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ToolTip.Tip="Back in page"
                                    Click="ModBrowserBackButton_Click">
                                <TextBlock Text="&#xE72B;"
                                           FontFamily="Segoe MDL2 Assets"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Background="{DynamicResource Theme.AppBg}">
                        <ContentControl x:Name="ModBrowserHost" />

                        <StackPanel x:Name="ModBrowserFallbackPanel"
                                    IsVisible="False"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8"
                                    Margin="16">
                            <TextBlock Text="Embedded browser unavailable."
                                       Foreground="{DynamicResource Theme.TextPrimary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="ModBrowserFallbackText"
                                       Text="Could not initialize in-app browser for this mod page."
                                       Foreground="{DynamicResource Theme.TextMuted}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
