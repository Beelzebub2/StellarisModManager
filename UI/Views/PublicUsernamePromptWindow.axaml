<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="StellarisModManager.UI.Views.PublicUsernamePromptWindow"
        Title="Choose Public Username"
        Width="520"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.AppBg}">

    <Border Margin="12"
            Padding="14"
            Background="{DynamicResource Theme.PanelBg}"
            BorderBrush="{DynamicResource Theme.Border}"
            BorderThickness="1"
            CornerRadius="12">
        <StackPanel Spacing="12">
            <TextBlock Text="Pick a public username"
                       Foreground="{DynamicResource Theme.TextPrimary}"
                       FontSize="18"
                       FontWeight="SemiBold" />

            <TextBlock Text="This name is shown when you share synced profiles. We do not use your Windows account name."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Theme.TextMuted}"
                       FontSize="13" />

            <TextBox x:Name="UsernameTextBox"
                     Watermark="Example: StarAdmiral"
                     MaxLength="40"
                     Background="{DynamicResource Theme.SurfaceBg}"
                     BorderBrush="{DynamicResource Theme.Border}"
                     Foreground="{DynamicResource Theme.TextPrimary}"
                     CornerRadius="8" />

            <TextBlock x:Name="ValidationText"
                       IsVisible="False"
                       Foreground="{DynamicResource Theme.Danger}"
                       FontSize="12"
                       Text="Please enter a username." />

            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,6,0,0">
                <Button Grid.Column="1"
                        Margin="0,0,8,0"
                        Background="{DynamicResource Theme.SurfaceBg}"
                        BorderBrush="{DynamicResource Theme.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,8"
                        Foreground="{DynamicResource Theme.TextPrimary}"
                        Content="Not now"
                        Click="CancelButton_Click" />

                <Button Grid.Column="2"
                        Background="{DynamicResource Theme.Accent}"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="12,8"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Content="Save"
                        Click="SaveButton_Click" />
            </Grid>
        </StackPanel>
    </Border>

</Window>
