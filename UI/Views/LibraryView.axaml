<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             xmlns:models="using:StellarisModManager.Core.Models"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.LibraryView"
             x:DataType="vm:LibraryViewModel"
             x:Name="Root"
             Background="{DynamicResource Theme.AppBg}">

    <UserControl.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
        </Style>

        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
        </Style>
        <Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
        </Style>

        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.list-header-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextMuted}" />
        </Style>

        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <Border Grid.Row="0"
                Margin="12,12,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Classes="icon-glyph" Foreground="{DynamicResource Theme.Accent}" Text="&#xE8F1;" />
                    <TextBlock Text="Installed Mods" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="16" FontWeight="SemiBold" />
                </StackPanel>

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Text="{Binding SearchText}"
                         Watermark="Search by mod name or workshop ID"
                         MinWidth="180"
                         Background="{DynamicResource Theme.SurfaceBg}"
                         BorderBrush="{DynamicResource Theme.Border}"
                         Foreground="{DynamicResource Theme.TextPrimary}"
                         CornerRadius="8" />

                <CheckBox Grid.Row="1"
                          Grid.Column="0"
                          Margin="0,8,0,0"
                          IsChecked="{Binding ShowEnabledOnly}"
                          Content="Enabled only"
                          Foreground="{DynamicResource Theme.TextPrimary}"
                          VerticalAlignment="Center" />

                <WrapPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Classes="toolbar" Command="{Binding CheckForUpdatesCommand}" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE895;" IsVisible="{Binding !IsCheckingUpdates}" />
                            <ProgressBar IsIndeterminate="True" Width="36" Height="5" IsVisible="{Binding IsCheckingUpdates}" />
                            <TextBlock Text="Check updates" />
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar"
                            Command="{Binding ReinstallAllModsCommand}"
                            IsEnabled="{Binding !IsReinstallingAllMods}"
                            Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE777;" IsVisible="{Binding !IsReinstallingAllMods}" />
                            <ProgressBar IsIndeterminate="True" Width="36" Height="5" IsVisible="{Binding IsReinstallingAllMods}" />
                            <TextBlock Text="Reinstall all" />
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar" x:Name="ExportButton" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE898;" />
                            <TextBlock Text="Export" />
                        </StackPanel>
                    </Button>

                    <Button Classes="toolbar" x:Name="ImportButton" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE896;" />
                            <TextBlock Text="Import" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="12,10,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*">
                <TextBlock Grid.Column="0" Text="Profile" Foreground="{DynamicResource Theme.TextMuted}" VerticalAlignment="Center" Margin="0,0,8,0" />

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Profiles}"
                          SelectedItem="{Binding ActiveProfile}"
                          MinWidth="200"
                          Background="{DynamicResource Theme.SurfaceBg}"
                          Foreground="{DynamicResource Theme.TextPrimary}"
                          BorderBrush="{DynamicResource Theme.Border}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ModProfile">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                    <ComboBox.SelectionBoxItemTemplate>
                        <DataTemplate x:DataType="models:ModProfile">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.SelectionBoxItemTemplate>
                </ComboBox>

                <Button Grid.Column="2" Classes="toolbar" Command="{Binding CreateProfileCommand}" Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="icon-glyph" Text="&#xE710;" />
                        <TextBlock Text="New" />
                    </StackPanel>
                </Button>

                <TextBox Grid.Column="3"
                         Text="{Binding ProfileNameDraft}"
                         Watermark="Profile name"
                         Width="180"
                         Margin="8,0,0,0"
                         IsVisible="{Binding IsRenamingProfile}"
                         Background="{DynamicResource Theme.SurfaceBg}"
                         BorderBrush="{DynamicResource Theme.Border}"
                         Foreground="{DynamicResource Theme.TextPrimary}"
                         CornerRadius="8" />

                <Button Grid.Column="4" Classes="toolbar" Command="{Binding BeginRenameProfileCommand}" Margin="8,0,0,0" IsVisible="{Binding !IsRenamingProfile}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="icon-glyph" Text="&#xE8AC;" />
                        <TextBlock Text="Rename" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Classes="toolbar" Command="{Binding RenameProfileCommand}" CommandParameter="{Binding ActiveProfile}" Margin="8,0,0,0" IsVisible="{Binding IsRenamingProfile}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Classes="icon-glyph" Text="&#xE73E;" />
                        <TextBlock Text="Apply" />
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
                    <Button Classes="toolbar" Command="{Binding DeleteProfileCommand}" CommandParameter="{Binding ActiveProfile}" IsEnabled="{Binding CanDeleteProfiles}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE74D;" />
                            <TextBlock Text="Delete" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding ShareProfileCommand}" CommandParameter="{Binding ActiveProfile}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE72D;" />
                            <TextBlock Text="Share" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0" VerticalAlignment="Center">
                    <TextBox Text="{Binding SharedProfileId}"
                             Watermark="Shared profile ID"
                             Width="170"
                             Background="{DynamicResource Theme.SurfaceBg}"
                             BorderBrush="{DynamicResource Theme.Border}"
                             Foreground="{DynamicResource Theme.TextPrimary}"
                             CornerRadius="8" />
                    <Button Classes="toolbar" Command="{Binding UseSharedProfileIdCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="icon-glyph" Text="&#xE8A7;" />
                            <TextBlock Text="Use ID" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="7"
                        HorizontalAlignment="Right"
                        Background="{DynamicResource Theme.SurfaceBg}"
                        BorderBrush="{DynamicResource Theme.Border}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="10,4"
                        IsVisible="{Binding HasUpdatesAvailable}">
                    <TextBlock Text="{Binding UpdatesAvailable, StringFormat='{}{0} updates available'}"
                               Foreground="{DynamicResource Theme.TextPrimary}"
                               FontSize="12" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="12,10,12,0" ColumnDefinitions="3*,2*">

            <Border Grid.Column="0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Background="{DynamicResource Theme.SurfaceBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="0,0,0,1"
                            Padding="12,8">
                        <Grid ColumnDefinitions="44,*,92,108">
                            <TextBlock Grid.Column="0" Classes="list-header-label" Text="Enabled" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Classes="list-header-label" Text="Name" Margin="6,0,0,0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Classes="list-header-label" Text="Load Order" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Classes="list-header-label" Text="Actions" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding FilteredMods}"
                             SelectedItem="{Binding SelectedMod}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:ModViewModel">
                                <Border BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                    <Grid ColumnDefinitions="44,*,92,108">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Command="{Binding ToggleEnabledCommand}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center" />

                                        <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,10,0">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Theme.TextPrimary}" />
                                                <Border Background="{DynamicResource Theme.SurfaceBg}"
                                                        BorderBrush="{DynamicResource Theme.Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="6,2"
                                                        IsVisible="{Binding HasUpdate}">
                                                    <TextBlock Text="Update"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Theme.Accent}" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Border Background="{DynamicResource Theme.SurfaceBg}" CornerRadius="8" Padding="6,2">
                                                    <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Theme.TextMuted}" />
                                                </Border>
                                                <Border Background="{DynamicResource Theme.SurfaceBg}" CornerRadius="8" Padding="6,2"
                                                        IsVisible="{Binding GameVersion, Converter={x:Static ObjectConverters.IsNotNull}}">
                                                    <TextBlock Text="{Binding GameVersion}" FontSize="11" Foreground="{DynamicResource Theme.TextMuted}" />
                                                </Border>
                                                <Border Background="{DynamicResource Theme.SurfaceBg}" CornerRadius="8" Padding="6,2"
                                                        IsVisible="{Binding IsMultiplayerSafeVisible}">
                                                    <TextBlock Text="MP safe" FontSize="11" Foreground="{DynamicResource Theme.Success}" />
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                MinWidth="42"
                                                Background="{DynamicResource Theme.SurfaceBg}"
                                                BorderBrush="{DynamicResource Theme.Border}"
                                                BorderThickness="1"
                                                CornerRadius="9"
                                                Padding="8,3">
                                            <TextBlock Text="{Binding LoadOrderDisplay}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource Theme.TextPrimary}" />
                                        </Border>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <Button Classes="icon-btn"
                                                    ToolTip.Tip="Move up"
                                                    IsVisible="{Binding IsEnabled}"
                                                    Command="{Binding #Root.((vm:LibraryViewModel)DataContext).MoveModUpCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Classes="icon-glyph" Text="&#xE70E;" />
                                            </Button>
                                            <Button Classes="icon-btn"
                                                    ToolTip.Tip="Move down"
                                                    IsVisible="{Binding IsEnabled}"
                                                    Command="{Binding #Root.((vm:LibraryViewModel)DataContext).MoveModDownCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Classes="icon-glyph" Text="&#xE70D;" />
                                            </Button>
                                            <Button Classes="icon-btn"
                                                    ToolTip.Tip="Remove"
                                                    Foreground="{DynamicResource Theme.Danger}"
                                                    Command="{Binding #Root.((vm:LibraryViewModel)DataContext).UninstallModCommand}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Classes="icon-glyph" Text="&#xE74D;" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Panel>
                    <TextBlock Text="Select a mod to view details"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="13"
                               IsVisible="{Binding SelectedMod, Converter={x:Static ObjectConverters.IsNull}}" />

                    <ScrollViewer IsVisible="{Binding SelectedMod, Converter={x:Static ObjectConverters.IsNotNull}}"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="16" Spacing="12" DataContext="{Binding SelectedMod}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Name}" FontSize="19" FontWeight="SemiBold" Foreground="{DynamicResource Theme.TextPrimary}" TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{DynamicResource Theme.SurfaceBg}" CornerRadius="8" Padding="8,4" IsVisible="{Binding IsMultiplayerSafeVisible}">
                                        <TextBlock Text="Multiplayer safe" Foreground="{DynamicResource Theme.Success}" FontSize="12" />
                                    </Border>
                                    <Border Background="{DynamicResource Theme.SurfaceBg}" CornerRadius="8" Padding="8,4" IsVisible="{Binding HasUpdate}">
                                        <TextBlock Text="Update available" Foreground="{DynamicResource Theme.Warning}" FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                      ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Workshop ID" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,0,12,0" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WorkshopId}" Foreground="{DynamicResource Theme.Accent}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,0,12,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version}" Foreground="{DynamicResource Theme.TextPrimary}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Subscribers" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,0,12,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding TotalSubscribersDisplay}" Foreground="{DynamicResource Theme.TextPrimary}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Reported support" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,0,12,0"
                                               IsVisible="{Binding GameVersion, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding GameVersion}" Foreground="{DynamicResource Theme.TextPrimary}"
                                               IsVisible="{Binding GameVersion, Converter={x:Static ObjectConverters.IsNotNull}}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Installed" Foreground="{DynamicResource Theme.TextMuted}" Margin="0,0,12,0" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding InstalledDate}" Foreground="{DynamicResource Theme.TextPrimary}" />
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12"
                                    IsVisible="{Binding TagsDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Tags" Foreground="{DynamicResource Theme.TextMuted}" FontSize="12" />
                                    <TextBlock Text="{Binding TagsDisplay}" Foreground="{DynamicResource Theme.TextPrimary}" FontSize="12" TextWrapping="Wrap"
                                               ToolTip.Tip="{Binding TagsDisplay}" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Actions" Foreground="{DynamicResource Theme.TextMuted}" FontSize="12" FontWeight="SemiBold" />
                            <StackPanel Spacing="6">
                                <WrapPanel Orientation="Horizontal" ItemHeight="40">
                                    <Button Width="162"
                                            IsVisible="{Binding HasUpdate}"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Update this mod"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.Success}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).UpdateModCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE895;" />
                                            <TextBlock Text="Update" />
                                        </StackPanel>
                                    </Button>

                                    <Button Width="162"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Reinstall this mod from Workshop"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.Accent}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).ReinstallModCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE777;" />
                                            <TextBlock Text="Reinstall" />
                                        </StackPanel>
                                    </Button>

                                    <Button Width="162"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Report this mod as working on your current game version"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.Success}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).ReportWorkedOnMyVersionCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding #Root.((vm:LibraryViewModel)DataContext).CanSubmitCompatibilityReport}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE73E;" />
                                            <TextBlock Text="Works for me" />
                                        </StackPanel>
                                    </Button>

                                    <Button Width="162"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Report this mod as not working on your current game version"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.Danger}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).ReportNotWorkedOnMyVersionCommand}"
                                            CommandParameter="{Binding}"
                                            IsEnabled="{Binding #Root.((vm:LibraryViewModel)DataContext).CanSubmitCompatibilityReport}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE711;" />
                                            <TextBlock Text="Broken for me" />
                                        </StackPanel>
                                    </Button>

                                    <Button Width="162"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Open this mod on the Steam Workshop"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.TextPrimary}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).OpenWorkshopPageCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE8A7;" />
                                            <TextBlock Text="Workshop" />
                                        </StackPanel>
                                    </Button>

                                    <Button Width="162"
                                            Margin="0,0,6,6"
                                            ToolTip.Tip="Open this mod folder"
                                            Background="{DynamicResource Theme.SurfaceBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            Foreground="{DynamicResource Theme.TextPrimary}"
                                            CornerRadius="8"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding #Root.((vm:LibraryViewModel)DataContext).OpenFileLocationCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <TextBlock Classes="icon-glyph" Text="&#xE838;" />
                                            <TextBlock Text="File location" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>

                                <Border Background="{DynamicResource Theme.SurfaceBg}"
                                        BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,8"
                                        IsVisible="{Binding #Root.((vm:LibraryViewModel)DataContext).CompatibilityReportSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding #Root.((vm:LibraryViewModel)DataContext).CompatibilityReportSummary}"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Button
                                ToolTip.Tip="Uninstall and remove this mod"
                                Background="{DynamicResource Theme.SurfaceBg}"
                                BorderBrush="{DynamicResource Theme.Border}"
                                BorderThickness="1"
                                Foreground="{DynamicResource Theme.Danger}"
                                CornerRadius="8"
                                Padding="10,8"
                                HorizontalContentAlignment="Center"
                                Command="{Binding #Root.((vm:LibraryViewModel)DataContext).UninstallModCommand}"
                                CommandParameter="{Binding}">
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                        <TextBlock Classes="icon-glyph" Text="&#xE74D;" />
                                        <TextBlock Text="Remove mod" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Panel>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Margin="12,10,12,12"
                Background="{DynamicResource Theme.SurfaceBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,7">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Background="{DynamicResource Theme.PanelBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5">
                        <TextBlock Text="{Binding TotalMods, StringFormat='Total: {0}'}"
                                   Foreground="{DynamicResource Theme.TextPrimary}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <Border Background="{DynamicResource Theme.PanelBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="10,5">
                        <TextBlock Text="{Binding ActiveMods, StringFormat='Enabled: {0}'}"
                                   Foreground="{DynamicResource Theme.Success}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Theme.Success}" FontSize="12"
                               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding UpdatesAvailable, StringFormat='Updates: {0}'}"
                           Foreground="{DynamicResource Theme.TextPrimary}"
                           FontSize="12"
                           IsVisible="{Binding HasUpdatesAvailable}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>

