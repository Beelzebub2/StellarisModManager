<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.BrowserView"
             x:DataType="vm:BrowserViewModel">

    <!-- Browser view placeholder - full implementation in Task 5 -->
    <Grid>
        <Border Background="#1E1E2E" CornerRadius="8" Margin="16">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="Steam Workshop Browser"
                           FontSize="22"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="#CDD6F4" />
                <TextBlock Text="WebView integration coming in Task 5"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="#6C7086" />
                <TextBlock Text="{Binding CurrentUrl}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           Foreground="#6C7086"
                           TextWrapping="Wrap"
                           MaxWidth="500" />
            </StackPanel>
        </Border>
    </Grid>

</UserControl>
