<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             xmlns:wv="using:AvaloniaWebView"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.BrowserView"
             x:DataType="vm:BrowserViewModel"
             Background="{DynamicResource Theme.AppBg}">

    <UserControl.Styles>
        <Style Selector="Button.nav-icon-btn">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="Button.nav-icon-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
        </Style>
        <Style Selector="Button.primary-btn">
            <Setter Property="Background" Value="{DynamicResource Theme.Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0" Margin="12,12,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
                <Button Grid.Column="0" x:Name="BackButton" Classes="nav-icon-btn" Click="BackButton_Click" ToolTip.Tip="Back">
                    <TextBlock Classes="icon-glyph" Text="&#xE72B;" />
                </Button>

                <Button Grid.Column="1" x:Name="ForwardButton" Classes="nav-icon-btn" Click="ForwardButton_Click" Margin="6,0,0,0" ToolTip.Tip="Forward">
                    <TextBlock Classes="icon-glyph" Text="&#xE72A;" />
                </Button>

                <Button Grid.Column="2" x:Name="RefreshButton" Classes="nav-icon-btn" Click="RefreshButton_Click" Margin="6,0,0,0" ToolTip.Tip="Refresh">
                    <TextBlock Classes="icon-glyph" Text="&#xE72C;" />
                </Button>

                <Button Grid.Column="3" Classes="nav-icon-btn" Click="HomeButton_Click" Margin="6,0,10,0" ToolTip.Tip="Workshop Home">
                    <TextBlock Classes="icon-glyph" Text="&#xE80F;" />
                </Button>

                <TextBox Grid.Column="4" x:Name="AddressInput"
                         Text="{Binding CurrentUrl, Mode=TwoWay}"
                         Watermark="Enter a URL"
                         Background="{DynamicResource Theme.SurfaceBg}"
                         BorderBrush="{DynamicResource Theme.Border}"
                         Foreground="{DynamicResource Theme.TextPrimary}"
                         CornerRadius="8"
                         VerticalContentAlignment="Center"
                         Padding="10,7"
                         KeyDown="AddressInput_KeyDown" />

                <Button Grid.Column="5" x:Name="GoButton" Classes="primary-btn" Content="Go" Margin="10,0,0,0" Click="GoButton_Click" />

                <StackPanel Grid.Column="6" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center" IsVisible="{Binding IsLoading}">
                    <ProgressBar IsIndeterminate="True" Width="52" Height="6" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12"
                Background="{DynamicResource Theme.AppBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True">
            <Grid>
                <wv:WebView x:Name="WebView" IsVisible="True" />

                <Border x:Name="FallbackPanel"
                        IsVisible="False"
                        Background="{DynamicResource Theme.AppBg}">
                    <ScrollViewer>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="620"
                                    Spacing="14"
                                    Margin="24">
                            <Border Background="{DynamicResource Theme.PanelBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Classes="icon-glyph" FontSize="18" Foreground="{DynamicResource Theme.Accent}" Text="&#xE8A7;" />
                                        <TextBlock Text="Embedded Browser Unavailable"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Theme.TextPrimary}" />
                                    </StackPanel>

                                    <TextBlock x:Name="BrowserErrorText"
                                               Text="The in-app browser could not load this page."
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               FontSize="13"
                                               TextWrapping="Wrap" />

                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="RetryInAppButton" Classes="primary-btn" Content="Retry In App" Click="RetryInAppButton_Click" />
                                        <Button x:Name="InstallRuntimeButton"
                                                Background="{DynamicResource Theme.SurfaceBg}"
                                                BorderBrush="{DynamicResource Theme.Border}"
                                                BorderThickness="1"
                                                Foreground="{DynamicResource Theme.TextPrimary}"
                                                CornerRadius="8"
                                                Padding="12,8"
                                                Content="Install WebView2 Runtime"
                                                Click="InstallRuntimeButton_Click" />
                                        <Button x:Name="OpenSteamButton"
                                                Background="{DynamicResource Theme.SurfaceBg}"
                                                BorderBrush="{DynamicResource Theme.Border}"
                                                BorderThickness="1"
                                                Foreground="{DynamicResource Theme.TextPrimary}"
                                                CornerRadius="8"
                                                Padding="12,8"
                                                Content="Open In Default Browser"
                                                Click="OpenSteamButton_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource Theme.PanelBg}" BorderBrush="{DynamicResource Theme.Border}" BorderThickness="1" CornerRadius="12" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Install Mod By Workshop ID"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}" />
                                    <TextBlock Text="Paste a Workshop ID or full URL to install directly."
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               FontSize="13" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBox x:Name="ModIdInput"
                                                 Grid.Column="0"
                                                 Watermark="Example: 123456789"
                                                 Background="{DynamicResource Theme.SurfaceBg}"
                                                 BorderBrush="{DynamicResource Theme.Border}"
                                                 Foreground="{DynamicResource Theme.TextPrimary}"
                                                 CornerRadius="8"
                                                 Padding="10,7"
                                                 Margin="0,0,8,0"
                                                 KeyDown="ModIdInput_KeyDown" />
                                        <Button Grid.Column="1"
                                                x:Name="InstallModButton"
                                                Classes="primary-btn"
                                                Content="Install"
                                                Click="InstallModButton_Click" />
                                    </Grid>

                                    <TextBlock x:Name="InstallStatusText"
                                               IsVisible="False"
                                               Foreground="{DynamicResource Theme.Success}"
                                               FontSize="12" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="12,0,12,12"
                Background="{DynamicResource Theme.SurfaceBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10,6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Classes="icon-glyph" Foreground="{DynamicResource Theme.TextMuted}" Text="&#xE946;" />
                <TextBlock Text="Browser overlay installs are active when Steam Workshop loads successfully."
                           Foreground="{DynamicResource Theme.TextMuted}"
                           FontSize="12" />
            </StackPanel>
        </Border>

    </Grid>

</UserControl>
