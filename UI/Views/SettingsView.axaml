<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:StellarisModManager.UI.ViewModels"
             mc:Ignorable="d"
             x:Class="StellarisModManager.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource Theme.AppBg}">

    <UserControl.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
        </Style>
        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                Margin="12,12,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14,12">
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="icon-glyph" Text="&#xE713;" Foreground="{DynamicResource Theme.Accent}" />
                    <TextBlock Text="Settings"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.TextPrimary}" />
                </StackPanel>
                <TextBlock Text="Organized controls for profile, game paths, workshop runtime, updates, and diagnostics."
                           FontSize="13"
                           Foreground="{DynamicResource Theme.TextMuted}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="12,10,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">
            <TabControl>

                <TabItem Header="General">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4" Spacing="12">
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Profile &amp; Sharing"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}" />
                                    <TextBlock Text="Public username shown when you share synced profiles."
                                               FontSize="12"
                                               Foreground="{DynamicResource Theme.TextMuted}" />

                                    <TextBox Text="{Binding PublicProfileUsername}"
                                             Watermark="Example: StarAdmiral"
                                             Background="{DynamicResource Theme.PanelBg}"
                                             BorderBrush="{DynamicResource Theme.Border}"
                                             Foreground="{DynamicResource Theme.TextPrimary}"
                                             CornerRadius="8" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                               Text="Game Installation"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                               Margin="0,0,0,8" />

                                    <TextBox Grid.Row="1" Grid.Column="0"
                                             Text="{Binding GamePath}"
                                             Watermark="Path to Stellaris installation folder"
                                             Background="{DynamicResource Theme.PanelBg}"
                                             BorderBrush="{DynamicResource Theme.Border}"
                                             Foreground="{DynamicResource Theme.TextPrimary}"
                                             CornerRadius="8"
                                             Margin="0,0,8,8" />
                                    <Button Grid.Row="1" Grid.Column="1"
                                            x:Name="BrowseGamePathButton"
                                            Classes="toolbar"
                                            Content="Browse"
                                            Margin="0,0,0,8" />

                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding ModsPath}"
                                             Watermark="Path to Paradox mods folder"
                                             Background="{DynamicResource Theme.PanelBg}"
                                             BorderBrush="{DynamicResource Theme.Border}"
                                             Foreground="{DynamicResource Theme.TextPrimary}"
                                             CornerRadius="8"
                                             Margin="0,0,8,8" />
                                    <Button Grid.Row="2" Grid.Column="1"
                                            x:Name="BrowseModsPathButton"
                                            Classes="toolbar"
                                            Content="Browse"
                                            Margin="0,0,0,8" />

                                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                                        <Button Classes="toolbar"
                                                Content="Auto detect"
                                                Command="{Binding AutoDetectCommand}" />
                                        <CheckBox IsChecked="{Binding AutoDetectGame}"
                                                  Content="Auto detect on startup"
                                                  Foreground="{DynamicResource Theme.TextPrimary}"
                                                  VerticalAlignment="Center" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                        <TextBlock Text="Detected game version"
                                                   Foreground="{DynamicResource Theme.TextMuted}"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding GameVersion}"
                                                   Foreground="{DynamicResource Theme.Accent}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>

                                    <CheckBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                              IsChecked="{Binding WarnBeforeRestartGame}"
                                              Content="Show save reminder before restarting Stellaris if it is already running"
                                              Foreground="{DynamicResource Theme.TextPrimary}"
                                              Margin="0,8,0,0" />
                                </Grid>
                            </Border>

                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <Grid ColumnDefinitions="Auto,220,Auto,*" VerticalAlignment="Center">
                                    <TextBlock Grid.Column="0"
                                               Text="Palette"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding PaletteOptions}"
                                              SelectedItem="{Binding SelectedPalette}"
                                              Background="{DynamicResource Theme.PanelBg}"
                                              BorderBrush="{DynamicResource Theme.Border}"
                                              Foreground="{DynamicResource Theme.TextPrimary}" />
                                    <Button Grid.Column="2"
                                            Classes="toolbar"
                                            Margin="10,0,0,0"
                                            Command="{Binding ApplyPaletteCommand}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Classes="icon-glyph" Text="&#xE790;" />
                                            <TextBlock Text="Apply" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Grid.Column="3"
                                               Text="Pick your preferred look before saving."
                                               Margin="10,0,0,0"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Workshop">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4" Spacing="12">
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                               Text="Workshop Download Runtime"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                               Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="Runtime"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,8" />
                                    <ComboBox Grid.Row="1" Grid.Column="1"
                                              ItemsSource="{Binding DownloadRuntimeOptions}"
                                              SelectedItem="{Binding SelectedDownloadRuntime}"
                                              Background="{DynamicResource Theme.PanelBg}"
                                              BorderBrush="{DynamicResource Theme.Border}"
                                              Foreground="{DynamicResource Theme.TextPrimary}"
                                              Margin="0,0,0,8"
                                              Width="220" />

                                    <TextBox Grid.Row="2" Grid.Column="0"
                                             Text="{Binding SteamCmdPath}"
                                             Watermark="Path to steamcmd.exe"
                                             Background="{DynamicResource Theme.PanelBg}"
                                             BorderBrush="{DynamicResource Theme.Border}"
                                             Foreground="{DynamicResource Theme.TextPrimary}"
                                             CornerRadius="8"
                                             Margin="0,0,8,8"
                                             IsVisible="{Binding IsSteamCmdPathRequired}" />
                                    <Button Grid.Row="2" Grid.Column="1"
                                            x:Name="BrowseSteamCmdPathButton"
                                            Classes="toolbar"
                                            Content="Browse"
                                            Margin="0,0,0,8"
                                            IsVisible="{Binding IsSteamCmdPathRequired}" />

                                    <TextBox Grid.Row="3" Grid.Column="0"
                                             Text="{Binding SteamCmdDownloadPath}"
                                             Watermark="SteamCMD download and workshop cache path"
                                             Background="{DynamicResource Theme.PanelBg}"
                                             BorderBrush="{DynamicResource Theme.Border}"
                                             Foreground="{DynamicResource Theme.TextPrimary}"
                                             CornerRadius="8"
                                             Margin="0,0,8,8"
                                             IsVisible="{Binding IsSteamCmdPathRequired}" />
                                    <Button Grid.Row="3" Grid.Column="1"
                                            x:Name="BrowseSteamCmdDownloadPathButton"
                                            Classes="toolbar"
                                            Content="Browse"
                                            Margin="0,0,0,8"
                                            IsVisible="{Binding IsSteamCmdPathRequired}" />

                                    <Grid Grid.Row="4" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto"
                                          IsVisible="{Binding IsSteamCmdPathRequired}">
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="SteamCMD status" Foreground="{DynamicResource Theme.TextMuted}" FontSize="12" />
                                            <TextBlock Text="Configured"
                                                       Foreground="{DynamicResource Theme.Success}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       IsVisible="{Binding IsSteamCmdConfigured}" />
                                            <TextBlock Text="Not configured"
                                                       Foreground="{DynamicResource Theme.Danger}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       IsVisible="{Binding !IsSteamCmdConfigured}" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Classes="toolbar"
                                                Command="{Binding DownloadSteamCmdCommand}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Classes="icon-glyph" Text="&#xE896;" />
                                                <TextBlock Text="Download SteamCMD" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Updates">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4" Spacing="12">
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*">
                                    <TextBlock Grid.Row="0"
                                               Text="App Updates"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}" />

                                    <Grid Grid.Row="1" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Text="Current" Foreground="{DynamicResource Theme.TextMuted}" FontSize="12" />
                                                <TextBlock Text="{Binding AppVersion}" Foreground="{DynamicResource Theme.Accent}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock Text="Latest" Foreground="{DynamicResource Theme.TextMuted}" FontSize="12" />
                                                <TextBlock Text="{Binding AppLatestVersion}"
                                                           Foreground="{DynamicResource Theme.Success}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           IsVisible="{Binding HasAppUpdateAvailable}" />
                                                <TextBlock Text="(up to date)"
                                                           Foreground="{DynamicResource Theme.TextMuted}"
                                                           FontSize="12"
                                                           IsVisible="{Binding !HasAppUpdateAvailable}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding LastAppUpdateCheckText, StringFormat='Last checked: {0}'}"
                                                       Foreground="{DynamicResource Theme.TextMuted}"
                                                       FontSize="12" />
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Classes="toolbar"
                                                VerticalAlignment="Top"
                                                Command="{Binding CheckForAppUpdatesCommand}"
                                                IsEnabled="{Binding !IsAppUpdateBusy}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Classes="icon-glyph" Text="&#xE895;" IsVisible="{Binding !IsCheckingAppUpdates}" />
                                                <ProgressBar IsIndeterminate="True" Width="36" Height="5" IsVisible="{Binding IsCheckingAppUpdates}" />
                                                <TextBlock Text="Check now" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <StackPanel Grid.Row="2" Margin="0,10,0,0" Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <CheckBox IsChecked="{Binding AutoCheckAppUpdates}"
                                                      Content="Auto-check updates"
                                                      Foreground="{DynamicResource Theme.TextPrimary}"
                                                      VerticalAlignment="Center" />

                                            <Border Background="{DynamicResource Theme.Danger}"
                                                    CornerRadius="999"
                                                    Padding="10,3"
                                                    IsVisible="{Binding IsAppUpdateCritical}">
                                                <TextBlock Text="Critical"
                                                           Foreground="#121417"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Classes="toolbar"
                                                    Content="Skip"
                                                    Command="{Binding SkipAppUpdateCommand}"
                                                    IsVisible="{Binding HasAppUpdateAvailable}"
                                                    IsEnabled="{Binding !IsAppUpdateCritical}" />

                                            <Button Classes="toolbar"
                                                    Command="{Binding InstallAppUpdateCommand}"
                                                    IsVisible="{Binding HasAppUpdateAvailable}"
                                                    IsEnabled="{Binding !IsAppUpdateBusy}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Classes="icon-glyph" Text="&#xE896;" />
                                                    <TextBlock Text="Install" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Margin="0,10,0,0" Spacing="6">
                                        <TextBlock Text="{Binding AppUpdateStep, StringFormat='Step: {0}'}"
                                                   Foreground="{DynamicResource Theme.TextPrimary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold" />

                                        <ProgressBar Minimum="0"
                                                     Maximum="100"
                                                     Height="8"
                                                     Value="{Binding AppUpdateProgressPercent}"
                                                     IsVisible="{Binding IsAppUpdateBusy}" />

                                        <TextBlock Text="{Binding AppUpdateDetails}"
                                                   Foreground="{DynamicResource Theme.TextMuted}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Advanced">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4" Spacing="12">
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Diagnostics"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Theme.TextPrimary}" />

                                    <Grid ColumnDefinitions="*,Auto">
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding DeveloperMode}"
                                                  Content="Developer mode (show SteamCMD/runtime logs)"
                                                  Foreground="{DynamicResource Theme.TextPrimary}" />

                                        <Button Grid.Column="1"
                                                Classes="toolbar"
                                                Content="Clear logs"
                                                Command="{Binding ClearDeveloperLogsCommand}"
                                                IsVisible="{Binding DeveloperMode}" />
                                    </Grid>

                                    <Border Background="{DynamicResource Theme.PanelBg}"
                                            BorderBrush="{DynamicResource Theme.Border}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            IsVisible="{Binding DeveloperMode}">
                                        <TextBox Text="{Binding DeveloperLogText}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="170"
                                                 MaxHeight="320"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource Theme.TextPrimary}"
                                                 FontFamily="Consolas, Cascadia Mono, Segoe UI"
                                                 FontSize="12" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Border>

        <Border Grid.Row="2"
                Margin="12,10,12,12"
                Background="{DynamicResource Theme.SurfaceBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Theme.Success}"
                           FontSize="12"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Text="Unsaved changes"
                           Foreground="{DynamicResource Theme.Warning}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           IsVisible="{Binding HasUnsavedChanges}" />

                <Button Grid.Column="2"
                        Classes="toolbar"
                        Content="Validate"
                        Command="{Binding ValidatePathsCommand}" />

                <Button Grid.Column="3"
                        Classes="toolbar"
                        Content="Save"
                        Margin="8,0,0,0"
                        Command="{Binding SaveSettingsCommand}" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
