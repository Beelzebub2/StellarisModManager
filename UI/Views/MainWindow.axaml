<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StellarisModManager.UI.ViewModels"
        xmlns:views="using:StellarisModManager.UI.Views"
        mc:Ignorable="d"
        x:Class="StellarisModManager.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Stellaris Mod Manager"
        Width="1320"
        Height="840"
        MinWidth="940"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="None"
        Background="{DynamicResource Theme.AppBg}"
        FontFamily="Inter, Segoe UI">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
        </Style>
        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource Theme.AppBg}">

        <Border Grid.Row="0"
                Margin="12,12,12,0"
                Background="{DynamicResource Theme.PanelBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                Padding="14,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <Border Width="30" Height="30"
                            Background="{DynamicResource Theme.SurfaceBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock Text="SM"
                                   Foreground="{DynamicResource Theme.Accent}"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Stellaris Mod Manager"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Theme.TextPrimary}" />
                        <TextBlock Text="Workshop download and library control"
                                   FontSize="12"
                                   Foreground="{DynamicResource Theme.TextMuted}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Text="{Binding AppVersion}"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="220,*" Margin="12">
            <Border Grid.Column="0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Margin="4,2,4,10">
                        <TextBlock Text="Navigation"
                                   FontSize="12"
                                   Foreground="{DynamicResource Theme.TextMuted}"
                                   Margin="6,0,0,8" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="6" HorizontalAlignment="Stretch">
                        <Grid>
                            <Button Classes="nav-btn" Command="{Binding NavigateToBrowserCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE774;" />
                                    <TextBlock Text="Browser" />
                                </StackPanel>
                            </Button>
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    IsVisible="{Binding IsBrowserActive}"
                                    IsHitTestVisible="False">
                                <Grid ColumnDefinitions="3,*">
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="10,0,0,10" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE774;" />
                                        <TextBlock Text="Browser" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid>
                            <Button Classes="nav-btn" Command="{Binding NavigateToLibraryCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE8F1;" />
                                    <TextBlock Text="Library" />
                                </StackPanel>
                            </Button>
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    IsVisible="{Binding IsLibraryActive}"
                                    IsHitTestVisible="False">
                                <Grid ColumnDefinitions="3,*">
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="10,0,0,10" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE8F1;" />
                                        <TextBlock Text="Library" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{DynamicResource Theme.SurfaceBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8"
                            Margin="4">
                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                            <Button Classes="nav-btn" Command="{Binding LaunchGameCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE768;" />
                                    <TextBlock Text="Start Game" />
                                </StackPanel>
                            </Button>

                            <Border Height="1" Background="{DynamicResource Theme.Border}" />

                            <Grid>
                                <Button Classes="nav-btn" Command="{Binding NavigateToSettingsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE713;" />
                                        <TextBlock Text="Settings" />
                                    </StackPanel>
                                </Button>
                                <Border Background="{DynamicResource Theme.PanelBg}"
                                        BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        IsVisible="{Binding IsSettingsActive}"
                                        IsHitTestVisible="False">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource Theme.Accent}"
                                                CornerRadius="10,0,0,10" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                            <TextBlock Classes="icon-glyph" Text="&#xE713;" />
                                            <TextBlock Text="Settings" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                <ContentControl Content="{Binding ActiveView}">
                    <ContentControl.DataTemplates>
                        <DataTemplate DataType="vm:BrowserViewModel">
                            <views:BrowserView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:LibraryViewModel">
                            <views:LibraryView />
                        </DataTemplate>
                        <DataTemplate DataType="vm:SettingsViewModel">
                            <views:SettingsView />
                        </DataTemplate>
                    </ContentControl.DataTemplates>
                </ContentControl>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="12,0,12,12"
                Background="{DynamicResource Theme.SurfaceBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Classes="icon-glyph" Foreground="{DynamicResource Theme.TextMuted}" Text="&#xE946;" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource Theme.TextPrimary}"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ProgressBar Grid.Column="1"
                             Value="{Binding DownloadProgress}"
                             Minimum="0"
                             Maximum="100"
                             Width="180"
                             Height="6"
                             Margin="10,0"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsDownloading}" />
            </Grid>
        </Border>

    </Grid>
</Window>
