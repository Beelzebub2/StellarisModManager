<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:StellarisModManager.UI.ViewModels"
        xmlns:views="using:StellarisModManager.UI.Views"
        mc:Ignorable="d"
        x:Class="StellarisModManager.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Stellaris Mod Manager"
        Width="1320"
        Height="840"
        MinWidth="940"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="None"
        Background="{DynamicResource Theme.AppBg}"
        FontFamily="Inter, Segoe UI">

    <Window.Styles>
        <Style Selector="Button.nav-btn">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.TextPrimary}" />
        </Style>
        <Style Selector="Button.nav-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
        </Style>
        <Style Selector="TextBlock.icon-glyph">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.status-chip">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="Border.status-chip-muted">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="Border.queue-panel">
            <Setter Property="Background" Value="{DynamicResource Theme.SurfaceBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="4,8,4,8" />
        </Style>
        <Style Selector="Border.queue-item">
            <Setter Property="Background" Value="{DynamicResource Theme.PanelBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="8,7" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Background="{DynamicResource Theme.AppBg}">

        <Grid Grid.Row="0" ColumnDefinitions="292,*" Margin="12">
            <Border Grid.Column="0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="10">
                <Grid RowDefinitions="Auto,*,Auto,Auto">
                    <StackPanel Grid.Row="0" Margin="4,2,4,10">
                        <TextBlock Text="Navigation"
                                   FontSize="12"
                                   Foreground="{DynamicResource Theme.TextMuted}"
                                   Margin="6,0,0,8" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Spacing="6" HorizontalAlignment="Stretch">
                        <Grid>
                            <Button Classes="nav-btn" Command="{Binding NavigateToVersionBrowserCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE81C;" />
                                    <TextBlock Text="By Version" />
                                </StackPanel>
                            </Button>
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    IsVisible="{Binding IsVersionBrowserActive}"
                                    IsHitTestVisible="False">
                                <Grid ColumnDefinitions="3,*">
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="10,0,0,10" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE81C;" />
                                        <TextBlock Text="By Version" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid>
                            <Button Classes="nav-btn" Command="{Binding NavigateToLibraryCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE8F1;" />
                                    <TextBlock Text="Library" />
                                </StackPanel>
                            </Button>
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    IsVisible="{Binding IsLibraryActive}"
                                    IsHitTestVisible="False">
                                <Grid ColumnDefinitions="3,*">
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="10,0,0,10" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE8F1;" />
                                        <TextBlock Text="Library" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid>
                            <Button Classes="nav-btn" Command="{Binding NavigateToWorkshopCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE774;" />
                                    <TextBlock Text="Workshop" />
                                </StackPanel>
                            </Button>
                            <Border Background="{DynamicResource Theme.SurfaceBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    IsVisible="{Binding IsWorkshopActive}"
                                    IsHitTestVisible="False">
                                <Grid ColumnDefinitions="3,*">
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource Theme.Accent}"
                                            CornerRadius="10,0,0,10" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE774;" />
                                        <TextBlock Text="Workshop" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="2" Classes="queue-panel">
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Install Queue"
                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding InstallQueueSummaryText}"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               FontSize="11" />
                                </StackPanel>

                                <Border Classes="status-chip" IsVisible="{Binding IsDownloading}">
                                    <TextBlock Text="{Binding DownloadProgress, StringFormat='{}{0}%'}"
                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Grid>

                            <ProgressBar Value="{Binding DownloadProgress}"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="7"
                                         IsVisible="{Binding IsDownloading}" />

                            <Border Background="{DynamicResource Theme.PanelBg}"
                                    BorderBrush="{DynamicResource Theme.Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,9"
                                    IsVisible="{Binding !HasInstallQueueItems}">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Classes="icon-glyph"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               Text="&#xE8D7;" />
                                    <TextBlock Text="No active installs"
                                               Foreground="{DynamicResource Theme.TextMuted}"
                                               FontSize="11" />
                                </StackPanel>
                            </Border>

                            <ScrollViewer MaxHeight="240" IsVisible="{Binding HasInstallQueueItems}">
                                <ItemsControl ItemsSource="{Binding InstallQueueItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:InstallQueueItemViewModel">
                                            <Border Classes="queue-item" Margin="0,0,0,6">
                                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                                    <TextBlock Grid.Row="0"
                                                               Grid.Column="0"
                                                               Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource Theme.TextPrimary}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <TextBlock Grid.Row="0"
                                                               Grid.Column="1"
                                                               Text="{Binding Progress, StringFormat='{}{0}%'}"
                                                               Foreground="{DynamicResource Theme.TextMuted}"
                                                               FontSize="11"
                                                               HorizontalAlignment="Right" />

                                                    <TextBlock Grid.Row="1"
                                                               Grid.ColumnSpan="2"
                                                               Text="{Binding Stage}"
                                                               Foreground="{DynamicResource Theme.Accent}"
                                                               FontSize="10"
                                                               Margin="0,4,0,2"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <ProgressBar Grid.Row="2"
                                                                 Grid.ColumnSpan="2"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Height="5"
                                                                 Value="{Binding Progress}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3"
                            Background="{DynamicResource Theme.SurfaceBg}"
                            BorderBrush="{DynamicResource Theme.Border}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,8"
                            Margin="4">
                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                            <Button Classes="nav-btn" Command="{Binding LaunchGameCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Classes="icon-glyph" Text="&#xE72C;" />
                                    <TextBlock Text="{Binding LaunchGameButtonText}" />
                                </StackPanel>
                            </Button>

                            <Border Height="1" Background="{DynamicResource Theme.Border}" />

                            <Grid>
                                <Button Classes="nav-btn" Command="{Binding NavigateToSettingsCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Classes="icon-glyph" Text="&#xE713;" />
                                        <TextBlock Text="Settings" />
                                    </StackPanel>
                                </Button>
                                <Border Background="{DynamicResource Theme.PanelBg}"
                                        BorderBrush="{DynamicResource Theme.Border}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        IsVisible="{Binding IsSettingsActive}"
                                        IsHitTestVisible="False">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource Theme.Accent}"
                                                CornerRadius="10,0,0,10" />
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="12,10">
                                            <TextBlock Classes="icon-glyph" Text="&#xE713;" />
                                            <TextBlock Text="Settings" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    Background="{DynamicResource Theme.PanelBg}"
                    BorderBrush="{DynamicResource Theme.Border}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Border IsVisible="{Binding IsWorkshopActive}">
                        <views:WorkshopView DataContext="{Binding WorkshopViewModel}" />
                    </Border>
                    <Border IsVisible="{Binding IsLibraryActive}">
                        <views:LibraryView DataContext="{Binding LibraryViewModel}" />
                    </Border>
                    <Border IsVisible="{Binding IsSettingsActive}">
                        <views:SettingsView DataContext="{Binding SettingsViewModel}" />
                    </Border>
                    <Border IsVisible="{Binding IsVersionBrowserActive}">
                        <views:VersionBrowserView DataContext="{Binding VersionBrowserViewModel}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Margin="12,0,12,12"
                Background="{DynamicResource Theme.SurfaceBg}"
                BorderBrush="{DynamicResource Theme.Border}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="12,7">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Theme.TextMuted}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />

                <Border Grid.Column="1" Classes="status-chip" Margin="8,0,0,0" IsVisible="{Binding IsDownloading}">
                    <TextBlock Text="{Binding QueueProgressText, StringFormat='Queue {0}'}"
                               Foreground="{DynamicResource Theme.TextPrimary}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>

                <Border Grid.Column="2" Classes="status-chip" Margin="8,0,0,0">
                    <Grid>
                        <TextBlock Text="{Binding StellarisyncConnectionStatus}"
                                   Foreground="{DynamicResource Theme.Success}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding IsStellarisyncOnline}" />
                        <TextBlock Text="{Binding StellarisyncConnectionStatus}"
                                   Foreground="{DynamicResource Theme.Warning}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   IsVisible="{Binding !IsStellarisyncOnline}" />
                    </Grid>
                </Border>

                <Border Grid.Column="3" Classes="status-chip-muted" Margin="8,0,0,0">
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0}'}"
                               Foreground="{DynamicResource Theme.TextMuted}"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
