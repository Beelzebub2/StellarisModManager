{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "node",
            "electron"
        ],
        "lib": [
            "ES2022",
            "DOM"
        ]
    },
    "include": [
        "src/main.ts",
        "src/preload.ts",
        "src/webviewPreload.ts",
        "src/main/**/*.ts",
        "src/shared/**/*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "src/renderer"
    ]
}
