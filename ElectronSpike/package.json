{
    "name": "stellaris-mod-manager-electron-spike",
    "version": "0.1.0",
    "private": true,
    "description": "Phase 1 Electron migration spike for Stellaris Mod Manager",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "start": "npm run build && electron .",
        "check": "tsc -p tsconfig.json --noEmit",
        "postinstall": "electron-rebuild -f -w better-sqlite3",
        "pack": "npm run build && electron-builder --win dir",
        "dist": "npm run build && electron-builder --win dir"
    },
    "build": {
        "appId": "com.stellaris.modmanager",
        "productName": "Stellaris Mod Manager",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "assets/**/*",
            "package.json"
        ],
        "win": {
            "icon": "assets/app.ico",
            "target": [
                "dir"
            ]
        },
        "mac": {
            "icon": "assets/icon.jpg"
        },
        "linux": {
            "icon": "assets/icon.jpg"
        },
        "extraResources": [
            "assets/**"
        ]
    },
    "dependencies": {
        "better-sqlite3": "^11.8.1"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@types/better-sqlite3": "^7.6.12",
        "@types/node": "^22.15.3",
        "electron": "^35.2.0",
        "electron-builder": "^26.8.1",
        "typescript": "^5.8.3"
    }
}